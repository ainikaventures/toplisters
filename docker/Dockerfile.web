# Production web image (Next.js standalone runtime).
# Three stages: install deps, build, slim runtime.

# ─── deps ─────────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl
COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN npm ci --no-audit --no-fund

# ─── build ────────────────────────────────────────────────────────────────
FROM node:22-alpine AS build
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Generate Prisma client (writes to lib/generated/prisma per schema config).
RUN npx prisma generate
# next build creates .next/standalone with the server + traced deps.
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ─── runtime ──────────────────────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl curl
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Standalone bundle + static assets + public + Prisma artefacts.
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public
# Prisma needs the schema + generated client at runtime for migrations.
COPY --from=build /app/prisma ./prisma
COPY --from=build /app/prisma.config.ts ./prisma.config.ts
COPY --from=build /app/lib/generated ./lib/generated
# Pragmatic choice: replace the standalone-traced node_modules with the full
# build-stage one. Prisma CLI (used by `prisma migrate deploy` at boot) has a
# deep web of transitive deps (effect, @prisma/config, prisma engines, WASM
# helpers in .bin/, etc.) that Next's tracer doesn't pick up because they're
# CLI-only. Selective copying turns into whack-a-mole; copying everything
# bloats the image from ~250MB to ~1.4GB but is reliable.
# Future cleanup: split into a separate "migrator" service that uses the build
# stage; keep web slim. Out of scope for initial deploy.
COPY --from=build /app/node_modules ./node_modules

EXPOSE 3000
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -fsS http://localhost:3000/jobs >/dev/null || exit 1

# server.js is created by Next standalone build at the standalone root.
CMD ["node", "server.js"]
