# Production web image (Next.js standalone runtime) for Coolify/Traefik.
# Three stages: install deps, build, slim non-root runtime.
#
# Contract:
#   - Listens on 0.0.0.0:${PORT:-8080} (no TLS in app — the proxy terminates it)
#   - Runs as the unprivileged `node` user
#   - GET /health → 200 with no dependency access (see app/health/route.ts)
#   - Stateless; logs to stdout/stderr; config 100% via env

# ─── deps ─────────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl
COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./
# --include=dev: build-time tooling (tailwindcss, @tailwindcss/postcss, etc.)
# lives in devDependencies. Coolify injects the app's NODE_ENV=production as a
# build ARG into every stage, which would make `npm ci` omit devDependencies
# and break `next build`. Force-include dev deps so the build is deterministic.
RUN npm ci --include=dev --no-audit --no-fund

# ─── build ────────────────────────────────────────────────────────────────
FROM node:22-alpine AS build
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Generate Prisma client (writes to lib/generated/prisma per schema config).
RUN npx prisma generate

# NEXT_PUBLIC_* values are inlined into the client bundle at `next build`
# time. They must be present as build args (runtime env is too late for
# anything baked into the client JS). Coolify passes these as build args;
# they fall back to empty strings so the build never fails when one is unset.
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_POSTHOG_KEY
ARG NEXT_PUBLIC_POSTHOG_HOST
ARG NEXT_PUBLIC_GA_ID
ARG NEXT_PUBLIC_CLARITY_ID
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL \
    NEXT_PUBLIC_POSTHOG_KEY=$NEXT_PUBLIC_POSTHOG_KEY \
    NEXT_PUBLIC_POSTHOG_HOST=$NEXT_PUBLIC_POSTHOG_HOST \
    NEXT_PUBLIC_GA_ID=$NEXT_PUBLIC_GA_ID \
    NEXT_PUBLIC_CLARITY_ID=$NEXT_PUBLIC_CLARITY_ID

# next build creates .next/standalone with the server + traced deps.
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ─── runtime ──────────────────────────────────────────────────────────────
FROM node:22-alpine AS runtime
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl curl
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Bind the standalone server to all interfaces on the platform port. The
# proxy reaches us on the internal network; there is NO host port mapping.
# server.js (Next standalone) reads both env vars at boot.
ENV HOSTNAME=0.0.0.0
ENV PORT=8080

# Standalone bundle + static assets + public + Prisma artefacts. Everything
# is owned by the unprivileged `node` user so the process can write its
# regeneratable banner cache (public/banners) without running as root.
COPY --from=build --chown=node:node /app/.next/standalone ./
COPY --from=build --chown=node:node /app/.next/static ./.next/static
COPY --from=build --chown=node:node /app/public ./public
# Prisma needs the schema + generated client at runtime for `migrate deploy`
# (the Coolify pre-deploy step runs `npx prisma migrate deploy` in this image).
COPY --from=build --chown=node:node /app/prisma ./prisma
COPY --from=build --chown=node:node /app/prisma.config.ts ./prisma.config.ts
COPY --from=build --chown=node:node /app/lib/generated ./lib/generated
# Pragmatic choice: replace the standalone-traced node_modules with the full
# build-stage one. Prisma CLI (used by the pre-deploy `prisma migrate deploy`)
# has a deep web of transitive deps (effect, @prisma/config, prisma engines,
# WASM helpers in .bin/, etc.) that Next's tracer doesn't pick up because
# they're CLI-only. Selective copying turns into whack-a-mole; copying
# everything bloats the image (~1.4 GB) but is reliable.
COPY --from=build --chown=node:node /app/node_modules ./node_modules

# Banner cache (public/banners/<hash>.jpg) is written at runtime; ensure the
# dir exists and is owned by `node`. It is regeneratable — losing it on
# redeploy only triggers lazy re-generation. Mount a persistent volume here
# if you want it to survive deploys (see DEPLOY.md → persistent paths).
RUN mkdir -p /app/public/banners && chown -R node:node /app/public/banners

USER node

EXPOSE 8080
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null || exit 1

# server.js is created by Next standalone build at the standalone root.
CMD ["node", "server.js"]
