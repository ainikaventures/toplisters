# Caddy reverse proxy + auto-TLS for toplisters.xyz.
# When you add the other 7 sites, paste a sibling block per host below
# and `docker compose -f docker/docker-compose.prod.yml restart caddy`.

(common) {
	encode gzip zstd
	header {
		# Security headers — sensible defaults; relax if a feature breaks.
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		# Allow Logo.dev images, Google Fonts, GA, PostHog, ipapi via CSP.
		# Tweak when you add image domains.
	}
	log {
		output stdout
		format console
	}
}

toplisters.xyz, www.toplisters.xyz {
	import common
	@www host www.toplisters.xyz
	redir @www https://toplisters.xyz{uri} permanent
	reverse_proxy web:3000
}
