// Toplisters.xyz — database schema
// Spec: info/PROJECT_SPEC.md (Unified Job Schema, lines 76–122)

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// DATABASE_URL is configured in prisma.config.ts (Prisma 7+ pattern).
datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum JobType {
  full_time
  part_time
  contract
  temp
  internship
}

enum WorkMode {
  remote
  hybrid
  onsite
  unknown
}

enum ExperienceLevel {
  entry
  mid
  senior
  exec
  unknown
}

enum CollarType {
  blue
  white
  grey
  unknown
}

enum SalaryPeriod {
  hourly
  daily
  monthly
  yearly
}

enum ModerationStatus {
  approved
  pending
  rejected
}

// ─── Models ───────────────────────────────────────────────────────────────

model Job {
  id               String           @id @default(cuid())
  source           String
  sourceId         String           @map("source_id")
  title            String
  companyName      String           @map("company_name")
  companyDomain    String?          @map("company_domain")
  companyLogoUrl   String?          @map("company_logo_url")
  locationText     String           @map("location_text")
  countryCode      String           @map("country_code") @db.Char(2)
  region           String?
  city             String?
  lat              Float
  lng              Float
  applyUrl         String           @map("apply_url")
  descriptionHtml  String           @map("description_html")
  descriptionText  String           @map("description_text")
  postedDate       DateTime         @map("posted_date")
  closingDate      DateTime?        @map("closing_date")
  lastSeenAt       DateTime         @map("last_seen_at")
  salaryMin        Int?             @map("salary_min")
  salaryMax        Int?             @map("salary_max")
  salaryCurrency   String?          @map("salary_currency") @db.Char(3)
  salaryPeriod     SalaryPeriod?    @map("salary_period")
  jobType          JobType          @map("job_type")
  workMode         WorkMode         @default(unknown) @map("work_mode")
  experienceLevel  ExperienceLevel  @default(unknown) @map("experience_level")
  category         String
  collarType       CollarType       @default(unknown) @map("collar_type")
  skills           String[]
  benefits         String[]
  visaSponsorship  Boolean?         @map("visa_sponsorship")
  // UK Register of Licensed Sponsors cross-reference (Task 8). Populated for
  // GB jobs by `npm run sponsors:refresh` (daily). null = not checked / non-UK.
  employerLicensedSponsor Boolean?  @map("employer_licensed_sponsor")
  sponsorRoutes           String[]  @default([]) @map("sponsor_routes")
  sponsorRating           String?   @map("sponsor_rating")
  sponsorMatchConfidence  String?   @map("sponsor_match_confidence")
  sponsorCheckedAt        DateTime? @map("sponsor_checked_at")
  // Freedom-oriented visa-pathway tags (Task 9) — derived from country + salary
  // (+ UK sponsor data). Filter columns; the API also computes the rich array
  // fresh on read. Refreshed daily by `npm run visa-pathways:refresh`.
  flexibleVisa            Boolean   @default(false) @map("flexible_visa")
  visaSchemes             String[]  @default([]) @map("visa_schemes")
  isUserSubmitted  Boolean          @default(false) @map("is_user_submitted")
  submittedByEmail String?          @map("submitted_by_email")
  moderationStatus ModerationStatus @default(approved) @map("moderation_status")
  isFeatured       Boolean          @default(false) @map("is_featured")
  viewCount        Int              @default(0) @map("view_count")
  clickCount       Int              @default(0) @map("click_count")
  isActive         Boolean          @default(true) @map("is_active")
  dedupeHash       String           @unique @map("dedupe_hash")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  // Generated column (see migration `add_jobs_search_vector`).
  // Declared as Unsupported so Prisma neither drops it nor tries to (re)create
  // it as a regular tsvector column.
  searchVector     Unsupported("tsvector")? @map("search_vector")

  clicks      JobClick[]
  submission  JobSubmission?
  socialPosts SocialPost[]

  @@unique([source, sourceId])
  @@index([countryCode, isActive])
  @@index([countryCode, city, isActive])
  @@index([category, isActive])
  @@index([isActive, postedDate(sort: Desc)])
  @@index([employerLicensedSponsor, isActive])
  @@index([flexibleVisa, isActive])
  @@index([isFeatured(sort: Desc), postedDate(sort: Desc)])
  @@index([lastSeenAt])
  @@map("jobs")
}

// User-submitted jobs go through a magic-link email confirmation before
// they reach the admin moderation queue. The Job row is created up-front
// in moderation_status=pending + is_active=false; the JobSubmission row
// holds the verification token.
model JobSubmission {
  id               String    @id @default(cuid())
  jobId            String    @unique @map("job_id")
  job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  email            String
  token            String    @unique
  emailConfirmedAt DateTime? @map("email_confirmed_at")
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([emailConfirmedAt])
  @@map("job_submissions")
}

// Per-click tracking for /api/jobs/[id]/click → 302 redirect (spec line 153).
model JobClick {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobId, createdAt])
  @@map("job_clicks")
}

// GeoNames cities500 dataset (~200k rows). Seeded via scripts/seed-geonames.ts.
model City {
  id          Int     @id @default(autoincrement())
  geonameId   Int     @unique @map("geoname_id")
  name        String
  asciiName   String  @map("ascii_name")
  countryCode String  @map("country_code") @db.Char(2)
  admin1Code  String? @map("admin1_code")
  admin2Code  String? @map("admin2_code")
  population  Int     @default(0)
  lat         Float
  lng         Float
  timezone    String?

  @@index([countryCode, name])
  @@index([countryCode, admin1Code, name])
  @@index([asciiName])
  @@map("cities")
}

// Cache of (company name → resolved logo URL) populated via Logo.dev
// brand-search. Stored once per distinct company so repeated aggregation
// runs don't burn the 5k/month free tier on lookups we already did.
// `logoUrl` is null when we tried but Logo.dev returned no match — we
// re-try on demand via `lookedUpAt` freshness checks at the call site.
model CompanyLogo {
  id              Int      @id @default(autoincrement())
  normalizedName  String   @unique @map("normalized_name")
  displayName     String   @map("display_name")
  domain          String?
  logoUrl         String?  @map("logo_url")
  lookedUpAt      DateTime @default(now()) @map("looked_up_at")

  @@map("company_logos")
}

// Email-alert subscribers. Phase-1.5 collection-only — actual digest
// sending is deferred until Resend's sending domain is verified
// post-deploy. Each subscriber confirms via magic-link before they're
// considered active (confirmedAt is set); unsubscribe is one-click via
// a separate token that lives forever in every digest email.
model Subscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  /// ISO-2 country codes the user wants alerts for; empty = all.
  countries        String[]  @default([])
  /// Work modes (remote / hybrid / onsite). Empty = all.
  workModes        String[]  @default([]) @map("work_modes")
  confirmToken     String    @unique @map("confirm_token")
  confirmedAt      DateTime? @map("confirmed_at")
  unsubscribeToken String    @unique @map("unsubscribe_token")
  unsubscribedAt   DateTime? @map("unsubscribed_at")
  lastSentAt       DateTime? @map("last_sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([confirmedAt, unsubscribedAt])
  @@map("subscribers")
}

// Auto-post audit log (spec amendment 2026-05-15). One row per
// (job, platform) — the @@unique([jobId, platform]) is the dedupe gate
// so a single job is never reposted to the same platform. Stores the
// platform-side post id + url for analytics and manual deletion.
model SocialPost {
  id           String   @id @default(cuid())
  jobId        String   @map("job_id")
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// Free-form platform key matching SocialPoster.platform — currently
  /// "facebook" | "telegram" | "twitter". Kept as a string (not an enum)
  /// so adding a platform is one file + env vars, no migration.
  platform     String
  /// "posted" | "failed" | "skipped" — "skipped" rows are written when
  /// the curator deliberately passes (quality gate, daily cap) so we
  /// don't re-evaluate the same job on the next run.
  status       String
  externalId   String?  @map("external_id")
  externalUrl  String?  @map("external_url")
  errorMessage String?  @map("error_message")
  postedAt     DateTime @default(now()) @map("posted_at")

  @@unique([jobId, platform])
  @@index([platform, postedAt])
  @@map("social_posts")
}

// First-party visitor analytics (spec amendment 2026-05-15).
// Cookieless: `visitorHash` = sha256(ip + ua + day-bucket + PAGEVIEW_SALT)
// truncated to 16 hex chars, so the same person has a stable id within a
// UTC day and a fresh one tomorrow. No IP/UA stored at rest, no cookies
// — feeds the /analytics/audience country-shape dashboard via
// COUNT(DISTINCT visitor_hash) for "visitors" and COUNT(*) for "visits".
model Pageview {
  id           BigInt   @id @default(autoincrement())
  occurredAt   DateTime @default(now()) @map("occurred_at")
  countryCode  String?  @map("country_code") @db.Char(2)
  path         String
  visitorHash  String   @map("visitor_hash") @db.Char(16)

  @@index([occurredAt])
  @@index([countryCode, occurredAt])
  @@index([visitorHash])
  @@map("pageviews")
}

// Cache of raw_location_string → resolved coordinates (spec line 70).
model GeocodeCache {
  id          Int      @id @default(autoincrement())
  rawLocation String   @unique @map("raw_location")
  countryCode String?  @map("country_code") @db.Char(2)
  region      String?
  city        String?
  lat         Float?
  lng         Float?
  hits        Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("geocode_cache")
}

// API keys for the read-only /api/v1/jobs endpoint (personal-use job
// scanner). Only the SHA-256 hash of each key is stored; the plaintext is
// shown once at creation. Manage with `npm run apikey`. Keys can also be
// supplied via the JOBS_API_KEYS env var (comma-separated plaintext) as a
// zero-DB bootstrap.
model ApiKey {
  id         String    @id @default(cuid())
  label      String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

// Recruiter-outreach email inbox. One thread per conversation; `token` is the
// plus-address tag (reply+<token>@<inbound domain>) used to route inbound
// replies (via Resend Inbound) back to the right thread.
model EmailThread {
  id             String         @id @default(cuid())
  token          String         @unique
  recruiterEmail String         @map("recruiter_email")
  recruiterName  String?        @map("recruiter_name")
  subject        String
  status         String         @default("open") // open | closed
  lastMessageAt  DateTime       @default(now()) @map("last_message_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  messages       EmailMessage[]

  @@index([lastMessageAt])
  @@map("email_threads")
}

model EmailMessage {
  id         String      @id @default(cuid())
  threadId   String      @map("thread_id")
  thread     EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction  String // "outbound" | "inbound"
  fromAddr   String      @map("from_addr")
  toAddr     String      @map("to_addr")
  subject    String
  text       String
  html       String?
  messageId  String?     @map("message_id")
  inReplyTo  String?     @map("in_reply_to")
  providerId String?     @map("provider_id")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@map("email_messages")
}
