# Copy this file to .env.local for Next.js and .env for Prisma CLI.
# Both files are git-ignored.

# ─── Database ──────────────────────────────────────────────────────────────
# Two roles per info/INFRASTRUCTURE.md §3:
#   - toplisters_app: runtime role used by web + worker (no DDL rights)
#   - toplisters: owner role used only by `prisma migrate` (via
#     MIGRATION_DATABASE_URL)
# Postgres binds to 5433 internally (§1 — avoids collision with SplitAI
# on the shared host).
POSTGRES_USER="toplisters"
POSTGRES_PASSWORD="toplisters"
POSTGRES_DB="toplisters"
TOPLISTERS_APP_PASSWORD="toplisters_app"
DATABASE_URL="postgresql://toplisters_app:toplisters_app@localhost:5433/toplisters?schema=public"
MIGRATION_DATABASE_URL="postgresql://toplisters:toplisters@localhost:5433/toplisters?schema=public"

# ─── Redis (BullMQ + cache) ────────────────────────────────────────────────
# Pinned to DB index 1 per info/INFRASTRUCTURE.md §1 (DB 0 reserved unused;
# SplitAI uses DB 2). The trailing /1 is what selects the index.
REDIS_URL="redis://localhost:6379/1"

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Job source API keys (added per-source as we wire each adapter) ────────
# Phase 1 sources requiring keys — sign up and paste here when ready.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
# Optional Adzuna tuning. Defaults give 18 countries × 1 page × 50 results
# per run, which uses ~29% of the 1000-call/day free tier at the default
# 90-min cadence. Bump pages if quota allows.
ADZUNA_COUNTRIES=""           # comma-sep ISO-2, e.g. "gb,us,de,in" (defaults to 18-country list in lib/sources/adzuna.ts)
ADZUNA_PAGES_PER_COUNTRY=""   # default 1
JOOBLE_API_KEY=""
# Optional Jooble tuning. Format: "Country Name:ISO2,Other:CC" — defaults
# query 10 large markets. Override to narrow or expand.
JOOBLE_LOCATIONS=""

# Phase 1 sources with no key required: RemoteOK, Arbeitnow.

# Phase 2 source keys (left blank for now).
REED_API_KEY=""
THE_MUSE_API_KEY=""
FINDWORK_API_KEY=""

# The Muse pagination cap (20 results per page; default 5 pages = 100 jobs).
# Increase if THE_MUSE_API_KEY is set and you want more US white-collar volume.
THE_MUSE_MAX_PAGES=""

# Per-source kill-switches (set to "1" to disable). Default: enabled.
DISABLE_SOURCE_REMOTEOK=""
DISABLE_SOURCE_ARBEITNOW=""
DISABLE_SOURCE_REED=""
DISABLE_SOURCE_THE_MUSE=""
DISABLE_SOURCE_ADZUNA=""
DISABLE_SOURCE_JOOBLE=""
DISABLE_SOURCE_FINDWORK=""
DISABLE_SOURCE_GREENHOUSE=""
DISABLE_SOURCE_LEVER=""

# ATS adapter company lists. Each company on Greenhouse / Lever has a
# slug (the path segment in their public board URL, e.g. "stripe" for
# https://boards.greenhouse.io/stripe). Comma-separated, lowercase.
# Defaults baked into lib/sources/greenhouse.ts + lever.ts.
GREENHOUSE_COMPANIES=""    # e.g. "stripe,airbnb,datadog,figma,…"
LEVER_COMPANIES=""         # e.g. "spotify,…"
# JSON-LD generic adapter: one kill-switch per configured site
# (see lib/sources/jsonld/sites.ts).
DISABLE_SOURCE_REMOTIVE=""
DISABLE_SOURCE_JOURNALISMJOBS=""
DISABLE_SOURCE_DESIGNJOBSBOARD=""

# ─── External services (free tiers) ────────────────────────────────────────
# Logo.dev — sign up at https://www.logo.dev (free tier: 5k img requests/month).
# Publishable key is embedded in image URLs (safe for client); secret key is
# used server-side for brand search (name → domain).
LOGO_DEV_PUBLISHABLE_KEY=""
LOGO_DEV_SECRET_KEY=""
RESEND_API_KEY=""
IPAPI_KEY="" # ipapi.co works without a key on free tier; left here for future paid plans.

# ─── Monitoring + Analytics ────────────────────────────────────────────────
# All optional; leave blank to disable each service individually.
# Sentry: error monitoring (free 5k errors/mo). Sign up at https://sentry.io.
SENTRY_DSN=""
# PostHog: product analytics, free 1M events/mo. EU-hosted by default.
# Sign up at https://posthog.com — paste the project key here.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# Google Analytics 4 — paste your measurement id (looks like "G-XXXXXXXXXX").
# Get one at https://analytics.google.com → Admin → Data streams.
NEXT_PUBLIC_GA_ID=""
# Microsoft Clarity — session recordings + heatmaps, free + unlimited.
# Get a project id at https://clarity.microsoft.com (looks like "wq71ep11xx").
NEXT_PUBLIC_CLARITY_ID=""

# ─── First-party visitor analytics (/analytics/audience) ───────────────────
# Salt for the daily-rotating visitor_hash (sha256(ip+ua+day+salt) truncated).
# Any random string works; rotating it invalidates any prior-day hashes
# (which were already going to rotate at the next UTC day boundary anyway).
# Keep it private. See lib/pageviews.ts.
PAGEVIEW_SALT=""

# ─── Admin ─────────────────────────────────────────────────────────────────
# HTTP basic auth for /admin/queue.
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me-locally"

# ─── Google AdSense ────────────────────────────────────────────────────────
# Phase-3 sponsored/featured listings will replace these slots; for now we
# run AdSense to validate monetization. All three of these must be set for
# any ad to render — leave blank to keep the site ad-free.
#
# Compliance: ads only load AFTER the user clicks Accept on the cookie
# banner (consent === "granted"). Manual placements only — no Auto Ads,
# Anchor, or Vignette ads.
#
# To wire up:
#   1. Sign in at https://adsense.google.com
#   2. Sites → confirm toplisters.xyz is approved
#   3. Ads → By ad unit → Create new (Display, Responsive). Make TWO units:
#        - "Toplisters / list"   → paste the numeric slot id below as SLOT_LIST
#        - "Toplisters / detail" → paste the numeric slot id below as SLOT_DETAIL
#   4. Set NEXT_PUBLIC_ADS_ENABLED="1" + redeploy
NEXT_PUBLIC_ADS_ENABLED="0"
NEXT_PUBLIC_ADSENSE_CLIENT=""        # e.g. "ca-pub-2028217968551720"
NEXT_PUBLIC_ADSENSE_SLOT_LIST=""     # /jobs page, between grid and pagination
NEXT_PUBLIC_ADSENSE_SLOT_DETAIL=""   # /job/[id]/[slug], between description and similar jobs
