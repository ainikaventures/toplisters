# Copy this file to .env.local for Next.js and .env for Prisma CLI.
# Both files are git-ignored. In production, Coolify injects these as the
# app's environment — nothing here is baked into the image except the
# NEXT_PUBLIC_* values forwarded as build args (see docker/Dockerfile.web).

# ─── Database (external, Coolify-managed) ──────────────────────────────────
# Postgres is an EXTERNAL Coolify resource — Coolify injects DATABASE_URL.
# The Coolify migration dropped the old toplisters_app / toplisters role
# split: a single managed role now serves both runtime queries and
# `prisma migrate deploy`.
#   - DATABASE_URL          : runtime + migrations (web, worker, pre-deploy)
#   - MIGRATION_DATABASE_URL: OPTIONAL. Only set if migrations should use a
#       higher-privilege role than runtime; prisma.config.ts falls back to
#       DATABASE_URL when unset.
# Local dev (docker-compose.dev.yml) exposes Postgres on 127.0.0.1:5433.
DATABASE_URL="postgresql://toplisters:toplisters@localhost:5433/toplisters?schema=public"
# MIGRATION_DATABASE_URL=""

# ─── Redis (BullMQ + cache, external/Coolify-managed) ──────────────────────
# Redis is an EXTERNAL Coolify resource — Coolify injects REDIS_URL. The
# trailing /1 selects DB index 1 (info/INFRASTRUCTURE.md §1).
# Local dev (docker-compose.dev.yml) exposes Redis on 127.0.0.1:6379.
REDIS_URL="redis://localhost:6379/1"

# ─── App ───────────────────────────────────────────────────────────────────
# Port the web server binds (0.0.0.0:$PORT). Traefik reaches the container
# here on the internal network. Defaults to 8080 if unset.
PORT="8080"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Sports vertical origin (sports.toplisters.xyz), for cross-vertical header
# links. BUILD-TIME (NEXT_PUBLIC_*). Blank ⇒ falls back to the relative
# "/sports" path (fine for local dev).
NEXT_PUBLIC_SPORTS_URL=""
NODE_ENV="development"

# ─── Job source API keys (added per-source as we wire each adapter) ────────
# Phase 1 sources requiring keys — sign up and paste here when ready.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
# Optional Adzuna tuning. Defaults give 18 countries × 1 page × 50 results
# per run, which uses ~29% of the 1000-call/day free tier at the default
# 90-min cadence. Bump pages if quota allows.
ADZUNA_COUNTRIES=""           # comma-sep ISO-2, e.g. "gb,us,de,in" (defaults to 18-country list in lib/sources/adzuna.ts)
ADZUNA_PAGES_PER_COUNTRY=""   # default 1
# Adzuna detail-enrichment: set DISABLE_ADZUNA_ENRICHMENT="1" to skip the
# per-job detail fetch; ADZUNA_ENRICH_CAP bounds how many jobs/run get enriched.
DISABLE_ADZUNA_ENRICHMENT=""
ADZUNA_ENRICH_CAP=""          # default in lib/sources/adzuna.ts
JOOBLE_API_KEY=""
# Optional Jooble tuning. Format: "Country Name:ISO2,Other:CC". Default covers
# 15 markets incl. the Gulf (AE/SA/QA/KW/OM/BH — our compliant Gulf coverage,
# since the regional boards block scraping). Override to narrow or expand.
JOOBLE_LOCATIONS=""

# Phase 1 sources with no key required: RemoteOK, Arbeitnow.

# Phase 2 source keys (left blank for now).
REED_API_KEY=""
THE_MUSE_API_KEY=""
FINDWORK_API_KEY=""

# The Muse pagination cap (20 results per page; default 5 pages = 100 jobs).
# Increase if THE_MUSE_API_KEY is set and you want more US white-collar volume.
THE_MUSE_MAX_PAGES=""
# Reed result cap per run (default in lib/sources/reed.ts).
REED_MAX_RESULTS=""
# Findwork pagination cap (default 1 page).
FINDWORK_MAX_PAGES=""

# Per-source kill-switches (set to "1" to disable). Default: enabled.
DISABLE_SOURCE_REMOTEOK=""
DISABLE_SOURCE_ARBEITNOW=""
DISABLE_SOURCE_REED=""
DISABLE_SOURCE_THE_MUSE=""
DISABLE_SOURCE_ADZUNA=""
DISABLE_SOURCE_JOOBLE=""
DISABLE_SOURCE_FINDWORK=""
DISABLE_SOURCE_GREENHOUSE=""
DISABLE_SOURCE_LEVER=""
DISABLE_SOURCE_RECRUITMENTREVOLUTION=""

# ATS adapter company lists. Each company on Greenhouse / Lever has a
# slug (the path segment in their public board URL, e.g. "stripe" for
# https://boards.greenhouse.io/stripe). Comma-separated, lowercase.
# Defaults baked into lib/sources/greenhouse.ts + lever.ts.
GREENHOUSE_COMPANIES=""    # e.g. "stripe,airbnb,datadog,figma,…"
LEVER_COMPANIES=""         # e.g. "spotify,…"
# Ashby ATS adapter. Company tokens are CASE-SENSITIVE (the path segment in
# https://jobs.ashbyhq.com/<token>). Defaults baked into lib/sources/ashby.ts.
ASHBY_COMPANIES=""         # e.g. "Ashby,Linear,Ramp,…"
DISABLE_SOURCE_ASHBY=""
# Recruitment Revolution (WordPress REST API). Pages of 100 to walk per run
# (default 12 ≈ all ~944 vacancies). Lower it to cap the per-run fetch.
RECRUITMENTREVOLUTION_MAX_PAGES=""
# SmartRecruiters ATS (direct apply links). Company identifiers are
# CASE-SENSITIVE (the path segment in api.smartrecruiters.com/v1/companies/<id>).
SMARTRECRUITERS_COMPANIES=""   # e.g. "Visa,Bosch,Square,…"
SMARTRECRUITERS_MAX=""         # max postings detail-fetched per company (default 60)
DISABLE_SOURCE_SMARTRECRUITERS=""
# Workday ATS (enterprise direct apply links). Tenants as "tenant:wdN:site",
# the path segments of <tenant>.<wdN>.myworkdayjobs.com/wday/cxs/<tenant>/<site>.
WORKDAY_TENANTS=""             # e.g. "nvidia:wd5:NVIDIAExternalCareerSite,cba:wd3:CommBank"
WORKDAY_MAX=""                 # max postings per tenant (default 60)
DISABLE_SOURCE_WORKDAY=""
# JSON-LD generic adapter: one kill-switch per configured site
# (see lib/sources/jsonld/sites.ts).
DISABLE_SOURCE_REMOTIVE=""
DISABLE_SOURCE_JOURNALISMJOBS=""
DISABLE_SOURCE_DESIGNJOBSBOARD=""

# ─── External services (free tiers) ────────────────────────────────────────
# Logo.dev — sign up at https://www.logo.dev (free tier: 5k img requests/month).
# Publishable key is embedded in image URLs (safe for client); secret key is
# used server-side for brand search (name → domain).
LOGO_DEV_PUBLISHABLE_KEY=""
LOGO_DEV_SECRET_KEY=""
# Resend transactional email (alert digests, confirmations). When
# RESEND_API_KEY is blank, lib/email.ts no-ops (logs instead of sending).
RESEND_API_KEY=""
# From-address for outbound mail. Defaults to "Toplisters <onboarding@resend.dev>"
# (Resend's shared sandbox) until your domain is verified.
RESEND_FROM=""
# ─── Recruiter outreach inbox (send + receive) ─────────────────────────────
# Two-way email with recruiters. Sends via Resend; replies arrive via Resend
# Inbound → /api/email/inbound. Admin UI at /admin/inbox.
# From-address for outreach (use a SUBDOMAIN like mail.toplisters.xyz to keep
# cold-outreach reputation off the apex). Falls back to RESEND_FROM.
OUTREACH_FROM=""              # e.g. "Toplisters <outreach@mail.toplisters.xyz>"
# Receiving domain whose MX points at Resend Inbound. Replies are routed by a
# plus tag: reply+<token>@<INBOUND_DOMAIN>.
INBOUND_DOMAIN=""             # e.g. "inbound.toplisters.xyz"
# Svix signing secret from the Resend webhook (Dashboard → Webhooks). Until
# this is set the inbound webhook is DISABLED (returns 503), failing closed.
RESEND_WEBHOOK_SECRET=""      # "whsec_…"
# Where the /contact form delivers (Reply-To is set to the sender). Falls back
# to ADMIN_EMAIL, then a built-in default. Each message is also logged to
# /admin/inbox.
CONTACT_TO=""                 # e.g. "hello@toplisters.xyz"
IPAPI_KEY="" # ipapi.co works without a key on free tier; left here for future paid plans.

# ─── Monitoring + Analytics ────────────────────────────────────────────────
# All optional; leave blank to disable each service individually.
# Sentry: error monitoring (free 5k errors/mo). Sign up at https://sentry.io.
SENTRY_DSN=""
# PostHog: product analytics, free 1M events/mo. EU-hosted by default.
# Sign up at https://posthog.com — paste the project key here.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
# Google Analytics 4 — paste your measurement id (looks like "G-XXXXXXXXXX").
# Get one at https://analytics.google.com → Admin → Data streams.
NEXT_PUBLIC_GA_ID=""
# Microsoft Clarity — session recordings + heatmaps, free + unlimited.
# Get a project id at https://clarity.microsoft.com (looks like "wq71ep11xx").
NEXT_PUBLIC_CLARITY_ID=""

# ─── First-party visitor analytics (/analytics/audience) ───────────────────
# Salt for the daily-rotating visitor_hash (sha256(ip+ua+day+salt) truncated).
# Any random string works; rotating it invalidates any prior-day hashes
# (which were already going to rotate at the next UTC day boundary anyway).
# Keep it private. See lib/pageviews.ts.
PAGEVIEW_SALT=""
# Salt for hashing IPs in the lightweight captcha/rate-limit (lib/captcha.ts).
# Falls back to ADMIN_PASSWORD then a dev default if unset — set a private
# random string in production.
IP_SALT=""

# ─── Admin ─────────────────────────────────────────────────────────────────
# HTTP basic auth for /admin/queue.
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me-locally"

# ─── Read-only jobs API (GET /api/v1/jobs) ─────────────────────────────────
# Auth for the external scanner. Two options (either works; can combine):
#   1. Bootstrap (zero-DB): comma-separated plaintext keys here. Simplest —
#      a presented key is accepted if it matches one of these.
#   2. Managed: create/revoke keys in the DB with `npm run apikey -- create`
#      (only the hash is stored; revoke without a redeploy).
# Keep keys private — this is a personal-use endpoint.
JOBS_API_KEYS=""
# Per-key rate limit, requests per minute (default 600). Fails open if Redis
# is unreachable so the API never goes down on rate-limit infra.
JOBS_API_RATE_LIMIT=""

# ─── AI features (free hosted LLM) ─────────────────────────────────────────
# Powers BOTH the sports win-path roadmap (/api/sports/roadmap) and the
# conversational job search (/api/jobs/chat — the LLM calls a search tool
# wired to the live listings). Key is server-side only; both features degrade
# gracefully when unset. Provider pluggable — default NVIDIA NIM (free,
# OpenAI-compatible; tool-calling required for job chat → use nvidia or groq).
SPORTS_AI_PROVIDER=""        # nvidia (default) | groq | gemini | ollama
# Generic key override. If blank, the provider falls back to its own var
# below (e.g. NVIDIA_KEY for the default provider).
SPORTS_AI_API_KEY=""
SPORTS_AI_MODEL=""           # e.g. "meta/llama-3.3-70b-instruct" (provider default otherwise)
SPORTS_AI_BASE_URL=""        # endpoint override (rarely needed)
# Provider-specific keys (used when SPORTS_AI_API_KEY is blank):
NVIDIA_KEY=""                # NVIDIA NIM (default provider) — get one at build.nvidia.com
GROQ_API_KEY=""
GEMINI_API_KEY=""

# ─── Sports — live data feeds ──────────────────────────────────────────────
# World Cup live group standings (points, played, W/D/L, goals) overlaid onto
# the Elo model. Free token from football-data.org/client/register. Blank ⇒
# the World Cup view falls back to the Elo projection. (F1 needs no key —
# live standings come from the public Jolpica-F1 API.)
FOOTBALL_DATA_ORG=""

# ─── Google AdSense ────────────────────────────────────────────────────────
# Phase-3 sponsored/featured listings will replace these slots; for now we
# run AdSense to validate monetization. All three of these must be set for
# any ad to render — leave blank to keep the site ad-free.
#
# Compliance: ads only load AFTER the user clicks Accept on the cookie
# banner (consent === "granted"). Manual placements only — no Auto Ads,
# Anchor, or Vignette ads.
#
# To wire up:
#   1. Sign in at https://adsense.google.com
#   2. Sites → confirm toplisters.xyz is approved
#   3. Ads → By ad unit → Create new (Display, Responsive). Make TWO units:
#        - "Toplisters / list"   → paste the numeric slot id below as SLOT_LIST
#        - "Toplisters / detail" → paste the numeric slot id below as SLOT_DETAIL
#   4. Set NEXT_PUBLIC_ADS_ENABLED="1" + redeploy
NEXT_PUBLIC_ADS_ENABLED="0"
NEXT_PUBLIC_ADSENSE_CLIENT=""        # e.g. "ca-pub-2028217968551720"
NEXT_PUBLIC_ADSENSE_SLOT_LIST=""     # /jobs page, between grid and pagination
NEXT_PUBLIC_ADSENSE_SLOT_DETAIL=""   # /job/[id]/[slug], between description and similar jobs

# ─── Social auto-posting ───────────────────────────────────────────────────
# Scheduler fires 3×/day at 08:30, 12:30, 17:30 UTC. Each tick posts up to
# `dailyCap` jobs per platform; platforms with SOCIAL_*_ENABLED!=1 (or
# missing creds) are silent no-ops. Daily caps are conservative — well
# under each API's free-tier ceiling. Override via SOCIAL_*_DAILY_CAP.
#
# Smoke test before flipping any platform on:
#   npm run post-to-social -- --dry        # show candidates, no API calls

# ── Facebook Page ──
# 1. Create the Page if you don't have one.
# 2. https://developers.facebook.com → My Apps → Create App → Business →
#    add the Page (or use an existing app) → Page Access Token with
#    `pages_manage_posts` scope. Long-lived tokens last 60 days; system-
#    user tokens on a verified business never expire.
# 3. Page ID: facebook.com/{page} → About → Page ID.
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
SOCIAL_FACEBOOK_ENABLED="0"
SOCIAL_FACEBOOK_DAILY_CAP=""    # default 3

# ── Telegram channel ──
# 1. DM @BotFather → /newbot → save the API token.
# 2. Create a public channel (e.g. @toplisters_jobs).
# 3. Add the bot as channel admin with "Post messages" permission.
# 4. TELEGRAM_CHANNEL_ID is "@toplisters_jobs" (include the @).
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""
SOCIAL_TELEGRAM_ENABLED="0"
SOCIAL_TELEGRAM_DAILY_CAP=""    # default 5

# ── X / Twitter ──
# 1. https://developer.x.com → free tier is enough for posting.
# 2. Project → app → User auth settings → OAuth 1.0a + Read & Write perms.
# 3. Keys and tokens → Consumer Keys (API key/secret) +
#    Access Token & Secret. If perms changed after generating Access
#    Token, REGENERATE it — old ones stay read-only.
# Free tier ceiling is 500 posts/month; default cap of 3/day = ~90/month.
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""
SOCIAL_TWITTER_ENABLED="0"
SOCIAL_TWITTER_DAILY_CAP=""     # default 3
